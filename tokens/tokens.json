  },

  "syntax": {
    "default":  { "$value": "var(--hbd-color-text-inverse)",   "$type": "color" },
    "keyword":  { "$value": "var(--hbd-color-gold-bright)",    "$type": "color" },
    "string":   { "$value": "var(--hbd-color-forest-300)",     "$type": "color" },
    "comment":  { "$value": "var(--hbd-color-ink-300)",        "$type": "color" },
    "number":   { "$value": "var(--hbd-color-sapphire-300)",   "$type": "color" },
    "function": { "$value": "var(--hbd-color-parchment-300)",  "$type": "color" },
    "operator": { "$value": "var(--hbd-color-parchment-100)",  "$type": "color" }
  },

  "spell-card": {
    "padding-y":      { "$value": "0.75rem",   "$type": "dimension" },
    "padding-x":      { "$value": "0.875rem",  "$type": "dimension" },
    "bar-height":     { "$value": "3px",       "$type": "dimension" },
    "badge-offset":   { "$value": "0.625rem",  "$type": "dimension" },
    "badge-pad-y":    { "$value": "2px",       "$type": "dimension" },
    "badge-pad-x":    { "$value": "6px",       "$type": "dimension" },
    "corner-size":    { "$value": "18px",      "$type": "dimension" },
    "corner-inset":   { "$value": "5px",       "$type": "dimension" },
    "corner-weight":  { "$value": "1.5px",     "$type": "dimension" },
    "shadow":          { "$value": "4px 4px 0 var(--hbd-color-parchment-400)", "$type": "shadow" },
    "shadow-selected": { "$value": "4px 4px 0 var(--hbd-color-gold-deep)",     "$type": "shadow" }
  },

  "stat-block": {
    "bar-width":         { "$value": "6px",                     "$type": "dimension" },
    "inner-pad-y":       { "$value": "1rem",                    "$type": "dimension" },
    "inner-pad-x":       { "$value": "1.25rem",                 "$type": "dimension" },
    "rule-gap":          { "$value": "0.625rem",                "$type": "dimension" },
    "ability-bg":        { "$value": "rgba(122, 18, 18, 0.06)", "$type": "color" },
    "ability-border":    { "$value": "rgba(122, 18, 18, 0.2)",  "$type": "color" },
    "ability-pad":       { "$value": "0.3125rem",               "$type": "dimension" },
    "ability-pad-tight": { "$value": "0.125rem",                "$type": "dimension" },
    "ability-head-size": { "$value": "0.625rem",                "$type": "dimension" },
    "name-gap":          { "$value": "2px",                     "$type": "dimension" },
    "feature-gap":       { "$value": "0.375rem",                "$type": "dimension" },
    "feature-leading":   { "$value": "1.55",                    "$type": "number" }
  }
}
